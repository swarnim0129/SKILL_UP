# Backend Environment Variables

# MongoDB
MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/<dbname>

# Clerk (for JWT verification)
CLERK_SECRET_KEY=sk_live_...
CLERK_PUBLISHABLE_KEY=pk_live_...

# Google Gemini AI
GEMINI_API_KEY=AIza...

# Cloudinary (resume uploads)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# JWT Secret (for admin auth)
JWT_SECRET=your_jwt_secret_here

# CORS — comma-separated list of allowed frontend origins
# On Render, set this to your Vercel domain(s)
CORS_ORIGIN=https://your-app.vercel.app,http://localhost:3000

# Port (Render sets this automatically)
PORT=5500

# Render sets RENDER_EXTERNAL_URL automatically — used for keep-alive ping
# No need to set manually
