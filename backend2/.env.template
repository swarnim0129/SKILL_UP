# Backend Environment Variables Template
# Copy this file and fill in your actual values

# MongoDB Configuration
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/morpheus?retryWrites=true&w=majority

# Security
SECRET_KEY=your-super-secret-jwt-key-min-32-characters-long
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# API Keys
GEMINI_API_KEY=your-gemini-api-key
OPENAI_API_KEY=your-openai-api-key-if-used
TAVILY_API_KEY=your-tavily-api-key-if-used
EXA_API_KEY=your-exa-api-key-if-used

# CORS Configuration
ALLOWED_ORIGINS=https://your-frontend-url.run.app,http://localhost:3000

# Application URLs
FRONTEND_URL=https://your-frontend-url.run.app

# VAPI Configuration (if using interview agent)
VAPI_API_KEY=your-vapi-key-if-used

# Optional: APScheduler Configuration
SCHEDULER_ENABLED=true
